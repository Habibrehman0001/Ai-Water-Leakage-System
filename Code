<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Water Leakage Detection System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @keyframes pulse-red {
            0%, 100% { background-color: rgba(220, 38, 38, 0.2); border-color: #ef4444; }
            50% { background-color: rgba(220, 38, 38, 0.5); border-color: #ff0000; }
        }
        .leak-active { animation: pulse-red 1.5s infinite; }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 font-sans min-h-screen p-4 md:p-8">

    <div class="max-w-6xl mx-auto">
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 border-b border-slate-700 pb-6 gap-4">
            <div>
                <h1 class="text-3xl font-bold bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">
                    HydroGuard AI Dashboard
                </h1>
                <p class="text-slate-400 text-sm">Real-time IoT Monitoring & Predictive Analytics</p>
            </div>
            <div id="statusBadge" class="flex items-center gap-2 bg-slate-800 px-4 py-2 rounded-full border border-slate-700">
                <div id="statusDot" class="w-3 h-3 rounded-full bg-green-500"></div>
                <span id="statusText" class="text-xs font-bold tracking-wider uppercase">System Secure</span>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl">
                <div class="flex justify-between text-slate-400 text-xs font-bold uppercase mb-4">
                    Flow Rate <i data-lucide="droplets" class="w-4 h-4 text-blue-400"></i>
                </div>
                <div class="flex items-baseline gap-2">
                    <span id="flowValue" class="text-5xl font-mono font-bold text-white">0.00</span>
                    <span class="text-slate-400">L/min</span>
                </div>
            </div>

            <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl">
                <div class="flex justify-between text-slate-400 text-xs font-bold uppercase mb-4">
                    Pressure <i data-lucide="activity" class="w-4 h-4 text-cyan-400"></i>
                </div>
                <div class="flex items-baseline gap-2">
                    <span id="pressureValue" class="text-5xl font-mono font-bold text-white">35</span>
                    <span class="text-slate-400">PSI</span>
                </div>
            </div>

            <div id="aiCard" class="bg-slate-800/50 p-6 rounded-2xl border border-slate-700 shadow-xl transition-all duration-300">
                <div class="flex justify-between text-slate-400 text-xs font-bold uppercase mb-4">
                    AI Analysis <i id="aiIcon" data-lucide="shield-check" class="w-4 h-4 text-green-500"></i>
                </div>
                <div id="aiAnalysisText" class="text-2xl font-bold text-green-500">Normal Flow</div>
                <div class="text-xs text-slate-500 mt-2">Anomaly Confidence: <span id="confidence">0.02%</span></div>
            </div>
        </div>

        <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden shadow-2xl">
            <div class="p-4 bg-slate-700/30 border-b border-slate-700 font-semibold flex items-center gap-2">
                <i data-lucide="list" class="w-4 h-4"></i> System Logs (Live)
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-900/50 text-slate-500 text-xs uppercase">
                        <tr>
                            <th class="px-6 py-3">Timestamp</th>
                            <th class="px-6 py-3">Flow Rate</th>
                            <th class="px-6 py-3">Pressure</th>
                            <th class="px-6 py-3">AI Verdict</th>
                        </tr>
                    </thead>
                    <tbody id="logTable" class="divide-y divide-slate-700">
                        </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // --- AI LOGIC SIMULATION ---
        const flowEl = document.getElementById('flowValue');
        const pressEl = document.getElementById('pressureValue');
        const aiCard = document.getElementById('aiCard');
        const aiText = document.getElementById('aiAnalysisText');
        const statusDot = document.getElementById('statusDot');
        const statusText = document.getElementById('statusText');
        const logTable = document.getElementById('logTable');
        const confidenceEl = document.getElementById('confidence');

        function updateSystem() {
            // Generate Simulated Sensor Data
            let flow = (Math.random() * 0.9).toFixed(2);
            let pressure = Math.floor(Math.random() * (40 - 30) + 30);
            
            // Randomly simulate a LEAK (10% chance)
            const isLeakEvent = Math.random() > 0.9;
            if (isLeakEvent) {
                flow = (Math.random() * (8.0 - 4.5) + 4.5).toFixed(2);
                pressure = Math.floor(Math.random() * (15 - 5) + 5);
            }

            // UI Update Logic
            flowEl.innerText = flow;
            pressEl.innerText = pressure;

            const isAnomalous = flow > 4.0; // Basic AI Threshold logic

            if (isAnomalous) {
                aiCard.className = "p-6 rounded-2xl border shadow-xl leak-active";
                aiText.innerText = "LEAK DETECTED";
                aiText.className = "text-2xl font-bold text-red-500";
                statusDot.className = "w-3 h-3 rounded-full bg-red-500 animate-ping";
                statusText.innerText = "ALARM ACTIVE";
                confidenceEl.innerText = "99.8%";
            } else {
                aiCard.className = "bg-slate-800/50 p-6 rounded-2xl border border-slate-700 shadow-xl";
                aiText.innerText = "Normal Flow";
                aiText.className = "text-2xl font-bold text-green-500";
                statusDot.className = "w-3 h-3 rounded-full bg-green-500";
                statusText.innerText = "System Secure";
                confidenceEl.innerText = (Math.random() * 0.5).toFixed(2) + "%";
            }

            // Add to Log Table
            const row = `
                <tr class="hover:bg-slate-700/20 transition-colors border-b border-slate-700/50">
                    <td class="px-6 py-4 font-mono text-xs text-slate-400">${new Date().toLocaleTimeString()}</td>
                    <td class="px-6 py-4">${flow} L/min</td>
                    <td class="px-6 py-4">${pressure} PSI</td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded text-[10px] font-bold ${isAnomalous ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400'}">
                            ${isAnomalous ? 'ANOMALY' : 'HEALTHY'}
                        </span>
                    </td>
                </tr>
            `;
            logTable.insertAdjacentHTML('afterbegin', row);

            // Limit table rows
            if (logTable.children.length > 8) logTable.lastElementChild.remove();
        }

        // Initialize Icons and Start Simulation
        lucide.createIcons();
        setInterval(updateSystem, 3000); // Update every 3 seconds
        updateSystem(); // Run immediately
    </script>
</body>
</html>
